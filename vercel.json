{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 1024,
      "maxDuration": 10,
      "config": {
        "forcePHPPECL": true
      }
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/clear-cache-gate",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_NAME": "Laravel",
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",
    "SESSION_SECURE_COOKIE": "true",
    "CACHE_DRIVER": "array",
    "VIEW_COMPILED_PATH": "/tmp",
    "NODE_VERSION": "18.x",
    "TELESCOPE_ENABLED": "false",
    "DEBUGBAR_ENABLED": "false",
    "DB_CONNECTION": "mysql",
    "DB_HOST": "YOUR_ACTUAL_REMOTE_DB_HOST_URL_OR_IP",
    "DB_PORT": "3306",
    "DB_DATABASE": "YOUR_ACTUAL_REMOTE_DB_NAME",
    "DB_USERNAME": "YOUR_ACTUAL_REMOTE_DB_USER",
    "DB_PASSWORD": "YOUR_ACTUAL_REMOTE_DB_PASSWORD",
    "APP_KEY": "base64:PASTE_YOUR_ACTUAL_APP_KEY_FROM_LOCAL_ENV_HERE="
  }
}
