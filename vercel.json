{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/clear-cache-gate",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_NAME": "Laravel",
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",
    "SESSION_SECURE_COOKIE": "true",
    "CACHE_DRIVER": "array",
    "VIEW_COMPILED_PATH": "/tmp",
    "NODE_VERSION": "18.x",
    "TELESCOPE_ENABLED": "false",
    "DEBUGBAR_ENABLED": "false",
    "DB_CONNECTION": "pgsql",
    "DB_HOST": "aws-1-ap-northeast-1.pooler.supabase.com",
    "DB_PORT": "6543",
    "DB_DATABASE": "postgres",
    "DB_USERNAME": "postgres.owqgxrnkqodtfzbrpjsn",
